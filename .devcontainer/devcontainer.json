{
    "name": "Skyfusion Analytics Dev Environment",
    "build": { "dockerfile": "Dockerfile" },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "GitHub.copilot",
                "GitHub.copilot-chat",
                "ms-toolsai.jupyter",
                "christian-kohler.path-intellisense"
            ]
        }
    },
    "remoteUser": "vscode",
    "postCreateCommand": "npm install && pip install -r requirements.txt"
}